async function fetchData() {
  const promise = await fetch("./data.json");
  if (promise.status != 200) return null;
  return await promise.json();
  //document.getElementById("a").innerHTML += "\\("+response[0].topics[0].value+"\\)";
  //renderMathInElement(document.body);
}

async function createOptions() {
  const data = await Promise.resolve(fetchData());
  console.log(data)

  const optionsSection = document.getElementById("options");

  for (const option of data) {
    const optionButton = document.createElement("button");
    optionButton.textContent = option.name;

    optionsSection.appendChild(optionButton);
  };
}


